{
  "appId": "com.inkmind.app",
  "appName": "InkMind",
  "webDir": "www",
  "android": {
    "backgroundColor": "#0a0908",
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0908",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
